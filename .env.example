# Shared service variables for local Docker development
SECRET_KEY=replace-with-strong-secret
DEBUG=True
DB_NAME=securecipher_db
DB_USER=securecipher_user
DB_PASSWORD=securecipher_password
DB_HOST=db
DB_PORT=5432
DB_SSLMODE=disable
LOCAL_DEV=True
BANKING_API_BASE_URL=http://server:8001

# Postgres container values
POSTGRES_USER=securecipher_user
POSTGRES_PASSWORD=securecipher_password
POSTGRES_DB=securecipher_db
